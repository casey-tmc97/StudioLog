<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="StudioLog.MarkNotesWindow"
        Title="Add Mark Notes"
        Width="500"
        Height="400"
        Background="#2d2d2d"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        KeyDown="Window_KeyDown">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Mark Notes"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- Text Input Area -->
        <Border Grid.Row="1"
                Background="#3a3a3a"
                BorderBrush="#555555"
                BorderThickness="1"
                CornerRadius="5"
                Padding="10">
            <TextBox Name="NotesTextBox"
                     AcceptsReturn="False"
                     TextWrapping="Wrap"
                     Background="Transparent"
                     Foreground="White"
                     BorderThickness="0"
                     FontSize="14"
                     Watermark="Enter your notes here..."
                     VerticalAlignment="Stretch"
                     HorizontalAlignment="Stretch"/>
        </Border>

        <!-- OK Button -->
        <Button Grid.Row="2"
                Content="OK"
                Click="OkButton_Click"
                Width="120"
                Height="40"
                Background="#a855f7"
                Foreground="White"
                FontWeight="Bold"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="0,20,0,0"
                CornerRadius="5"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"/>
    </Grid>
</Window>
