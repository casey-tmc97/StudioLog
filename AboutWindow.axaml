<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="StudioLog.AboutWindow"
        Title="About StudioLog"
        Width="500"
        Height="400"
        Background="#2d2d2d"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <Grid Margin="40">
        <StackPanel Spacing="20" VerticalAlignment="Center">
            
            <!-- App Title -->
            <TextBlock Text="StudioLog"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"/>
            
            <!-- Version -->
            <TextBlock Text="Version 4.0"
                       FontSize="16"
                       Foreground="#888"
                       HorizontalAlignment="Center"/>
            
            <!-- Description -->
            <TextBlock Text="Professional SMPTE LTC timecode logging application for video/audio production with NDI integration and NTP synchronization."
                       FontSize="14"
                       Foreground="White"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,10,0,0"/>
            
            <!-- Features -->
            <StackPanel Spacing="8" Margin="0,20,0,0">
                <TextBlock Text="✓ Industry-standard LTC via libltc"
                           Foreground="White"
                           FontSize="12"/>
                <TextBlock Text="✓ NTP synchronized timecode"
                           Foreground="White"
                           FontSize="12"/>
                <TextBlock Text="✓ NDI send/receive for IP timecode"
                           Foreground="White"
                           FontSize="12"/>
                <TextBlock Text="✓ Multiple frame rates (24, 25, 29.97 DF/NDF, 30 fps)"
                           Foreground="White"
                           FontSize="12"/>
                <TextBlock Text="✓ Professional audio (System/ASIO)"
                           Foreground="White"
                           FontSize="12"/>
                <TextBlock Text="✓ PDF, CSV, PNG export"
                           Foreground="White"
                           FontSize="12"/>
            </StackPanel>
            
            <!-- Copyright -->
            <TextBlock Text="© 2025 StudioLog"
                       FontSize="12"
                       Foreground="#666"
                       HorizontalAlignment="Center"
                       Margin="0,20,0,0"/>
            
            <!-- Close Button -->
            <Button Content="Close"
                    Click="CloseButton_Click"
                    Width="100"
                    Height="35"
                    Background="#555555"
                    Foreground="White"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</Window>
